<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen font-['Inter'] selection:bg-indigo-100">

    <div class="max-w-6xl mx-auto px-4 py-16">
        <!-- Header Section -->
        <header class="flex flex-col md:flex-row md:items-end md:justify-between mb-12 gap-4 border-b border-slate-200 pb-8">
            <div>
                <h1 class="text-4xl font-extrabold tracking-tight text-indigo-600">
                    LensaCerdas<span class="text-slate-400">.</span>
                </h1>
                <p class="text-slate-500 font-medium mt-1">Intelligence Administrative Dashboard</p>
            </div>
            <div class="flex items-center gap-3">
                <span class="flex h-3 w-3 rounded-full bg-emerald-500"></span>
                <span class="text-sm font-semibold text-slate-600 uppercase tracking-wider">Server Operational</span>
            </div>
        </header>

        <!-- Main Content Area -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                <h2 class="font-bold text-slate-800 text-lg">Study Summaries History</h2>
                <span class="bg-white px-3 py-1 rounded-full border border-slate-200 text-xs font-bold text-slate-500 shadow-sm">
                    <%= summaries.length %> Records
                </span>
            </div>

            <% if (summaries && summaries.length > 0) { %>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-slate-400 text-[11px] uppercase tracking-[0.2em] font-bold">
                                <th class="px-8 py-4">Title</th>
                                <th class="px-8 py-4">Brief Summary</th>
                                <th class="px-8 py-4">Generated Date</th>
                                <th class="px-8 py-4 text-right">Management</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            <% summaries.forEach(item => { %>
                                <tr id="row-<%= item.id %>" class="hover:bg-slate-50/80 transition-colors group">
                                    <td class="px-8 py-6">
                                        <div class="font-bold text-slate-700 group-hover:text-indigo-600 transition-colors">
                                            <%= item.title %>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <p class="text-slate-500 text-sm line-clamp-2 max-w-sm leading-relaxed">
                                            <%= item.summary_text %>
                                        </p>
                                    </td>
                                    <td class="px-8 py-6">
                                        <span class="text-slate-400 text-sm tabular-nums">
                                            <%= new Date(item.created_at).toLocaleDateString('en-GB') %>
                                        </span>
                                    </td>
                                    <td class="px-8 py-6 text-right">
                                        <button onclick="deleteSummary('<%= item.id %>')" 
                                            class="text-rose-500 text-xs font-bold uppercase tracking-widest hover:text-rose-700 hover:bg-rose-50 px-3 py-2 rounded-lg transition-all">
                                            Remove
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="py-32 text-center flex flex-col items-center">
                    <div class="bg-slate-100 p-5 rounded-full mb-4">
                        <svg class="w-8 h-8 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-slate-700">No data available</h3>
                    <p class="text-slate-400 text-sm mt-1">Please process your study material via the mobile app.</p>
                </div>
            <% } %>
        </div>

        <footer class="mt-16 text-center">
            <p class="text-slate-300 text-[10px] font-bold uppercase tracking-[0.3em]">
                System Version 1.0.4 &bull; Distributed Server Architecture
            </p>
        </footer>
    </div>

    <script>
        async function deleteSummary(id) {
            if (!confirm('Are you sure? This action cannot be undone.')) return;

            try {
                const response = await fetch(`/api/delete/${id}`, { method: 'DELETE' });
                const result = await response.json();
                
                if (result.success) {
                    const row = document.getElementById(`row-${id}`);
                    row.style.opacity = '0';
                    setTimeout(() => {
                        row.remove();
                        if (document.querySelectorAll('tbody tr').length === 0) location.reload();
                    }, 300);
                } else {
                    alert('Error: ' + result.message);
                }
            } catch (error) {
                alert('Connection error');
            }
        }
    </script>
</body>
</html>