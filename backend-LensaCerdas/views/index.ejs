<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    animation: {
                        'fade-in-down': 'fadeInDown 0.6s ease-out',
                        'fade-in-up': 'fadeInUp 0.6s ease-out',
                        'fade-in': 'fadeIn 0.4s ease-out',
                        'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    },
                    keyframes: {
                        fadeInDown: {
                            '0%': { opacity: '0', transform: 'translateY(-20px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        },
                        fadeInUp: {
                            '0%': { opacity: '0', transform: 'translateY(20px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' },
                        },
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' },
                        }
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        /* Custom scrollbar for webkit */
        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 4px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #94a3b8;
        }
    </style>
</head>

<body class="bg-slate-50 text-slate-900 min-h-screen font-['Inter'] selection:bg-indigo-100">

    <div class="max-w-6xl mx-auto px-4 py-16">
        <!-- Header Section -->
        <header
            class="flex flex-col md:flex-row md:items-end md:justify-between mb-12 gap-4 border-b border-slate-200 pb-8 animate-fade-in-down">
            <div>
                <h1
                    class="text-4xl font-extrabold tracking-tight text-indigo-600 transition-transform hover:scale-105 duration-300 inline-block cursor-default">
                    LensaCerdas<span class="text-slate-400 animate-pulse-slow inline-block">.</span>
                </h1>
                <p class="text-slate-500 font-medium mt-1">Intelligence Administrative Dashboard</p>
            </div>
            <div class="flex items-center gap-4">
                <div
                    class="flex items-center gap-2 mr-4 bg-white px-4 py-2 rounded-full shadow-sm border border-slate-100">
                    <span class="flex h-3 w-3 rounded-full bg-emerald-500 animate-[pulse_2s_infinite]"></span>
                    <span class="text-sm font-semibold text-slate-600 uppercase tracking-wider">Server
                        Operational</span>
                </div>
                <a href="/logout"
                    class="bg-white hover:bg-rose-50 text-slate-600 hover:text-rose-600 border border-slate-200 hover:border-rose-200 text-sm font-bold py-2 px-5 rounded-xl transition-all duration-300 shadow-sm hover:shadow active:scale-95">
                    Logout
                </a>
            </div>
        </header>

        <!-- Main Content Area -->
        <div
            class="bg-white rounded-2xl shadow-lg shadow-indigo-100/30 border border-slate-200 overflow-hidden animate-fade-in-up">
            <div
                class="px-8 py-6 border-b border-slate-100 flex flex-wrap items-center justify-between bg-slate-50/50 gap-4">
                <div class="flex items-center gap-4">
                    <h2 class="font-bold text-slate-800 text-lg">Study Summaries History</h2>
                    <span
                        class="bg-indigo-50 px-3 py-1 rounded-full border border-indigo-100 text-xs font-bold text-indigo-600 shadow-sm">
                        <%= summaries.length %> Records
                    </span>
                </div>
                <button onclick="openModal('add')"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-bold py-2.5 px-5 rounded-xl shadow-md shadow-indigo-600/20 hover:shadow-lg hover:shadow-indigo-600/40 transition-all duration-300 hover:-translate-y-0.5 active:scale-95 flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Add New Summary
                </button>
            </div>

            <% if (summaries && summaries.length > 0) { %>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-slate-400 text-[11px] uppercase tracking-[0.2em] font-bold bg-white">
                                <th class="px-8 py-5">Title</th>
                                <th class="px-8 py-5">Brief Summary</th>
                                <th class="px-8 py-5">Created By</th>
                                <th class="px-8 py-5">Generated Date</th>
                                <th class="px-8 py-5 text-right">Management</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100 bg-slate-50/20">
                            <% summaries.forEach((item, index) => { %>
                                <tr id="row-<%= item.id %>"
                                    class="hover:bg-white hover:shadow-md hover:shadow-slate-200/50 transition-all duration-300 group hover:-translate-y-[1px] relative z-0 hover:z-10"
                                    style="animation: fadeIn 0.4s ease-out <%= index * 0.05 %>s both;">
                                    <td class="px-8 py-6">
                                        <div
                                            class="font-bold text-slate-700 group-hover:text-indigo-600 transition-colors duration-300">
                                            <%= item.title %>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <p class="text-slate-500 text-sm line-clamp-2 max-w-xs leading-relaxed group-hover:text-slate-700 transition-colors duration-300"
                                            id="summary-text-<%= item.id %>">
                                            <%= item.summary_text %>
                                        </p>
                                    </td>
                                    <td class="px-8 py-6">
                                        <div class="flex items-center gap-3">
                                            <div
                                                class="w-8 h-8 rounded-full bg-gradient-to-br from-indigo-100 to-purple-100 flex items-center justify-center text-indigo-700 text-xs font-bold shadow-sm ring-2 ring-white">
                                                <%= item.users && item.users.name ? item.users.name.charAt(0).toUpperCase() : 'U' %>
                                            </div>
                                            <span
                                                class="text-slate-600 text-sm font-semibold group-hover:text-indigo-600 transition-colors duration-300">
                                                <%= item.users && item.users.name ? item.users.name : 'Unknown User' %>
                                            </span>
                                        </div>
                                    </td>
                                    <td class="px-8 py-6">
                                        <span
                                            class="text-slate-500 text-sm tabular-nums font-medium bg-slate-100 px-2.5 py-1 rounded-md">
                                            <%= new Date(item.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                        </span>
                                    </td>
                                    <td class="px-8 py-6 text-right space-x-2 whitespace-nowrap">
                                        <button
                                            onclick="openModal('edit', '<%= item.id %>', '<%= item.title.replace(/'/g, "\\'") %>', document.getElementById('summary-text-<%= item.id %>').innerText)"
                                            class="text-indigo-500 bg-indigo-50/50 text-xs font-bold uppercase tracking-widest hover:text-white hover:bg-indigo-500 px-4 py-2 rounded-xl transition-all duration-300 active:scale-95 shadow-sm hover:shadow-md hover:shadow-indigo-500/20">
                                            Edit
                                        </button>
                                        <button onclick="deleteSummary('<%= item.id %>')"
                                            class="text-rose-500 bg-rose-50/50 text-xs font-bold uppercase tracking-widest hover:text-white hover:bg-rose-500 px-4 py-2 rounded-xl transition-all duration-300 active:scale-95 shadow-sm hover:shadow-md hover:shadow-rose-500/20">
                                            Remove
                                        </button>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="py-32 text-center flex flex-col items-center animate-fade-in">
                    <div class="bg-indigo-50 p-6 rounded-full mb-5 shadow-inner">
                        <svg class="w-10 h-10 text-indigo-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-slate-800 text-xl">No data available</h3>
                    <p class="text-slate-500 text-sm mt-2 max-w-sm">Please process your study material via the
                        mobile app or create a new summary manually.</p>
                </div>
            <% } %>
        </div>

        <footer class="mt-16 text-center animate-fade-in-up" style="animation-delay: 0.2s; animation-fill-mode: both;">
            <p
                class="text-slate-400 text-[10px] font-bold uppercase tracking-[0.3em] flex items-center justify-center gap-2">
                <span>System Version 1.0.4</span>
                <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                <span>Distributed Server Architecture</span>
            </p>
        </footer>
    </div>

    <!-- Modal Form overlay -->
    <div id="crudModalOverlay"
        class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-300">
    </div>

    <!-- Modal Content -->
    <div id="crudModalContent" class="fixed inset-0 z-50 hidden items-center justify-center p-4">
        <div id="crudModalBox"
            class="bg-white rounded-2xl shadow-2xl border border-slate-200 w-full max-w-lg overflow-hidden transform scale-95 opacity-0 transition-all duration-300">
            <div
                class="px-8 py-5 border-b border-slate-100 flex justify-between items-center bg-slate-50/80 backdrop-blur">
                <h3 id="modalTitle" class="font-bold text-slate-800 text-xl">Add New Summary</h3>
                <button onclick="closeModal()"
                    class="text-slate-400 hover:text-slate-700 bg-white hover:bg-slate-100 p-2 rounded-full transition-colors duration-200">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                            d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
            <div class="p-8">
                <form id="crudForm" class="space-y-5">
                    <input type="hidden" id="formId">
                    <input type="hidden" id="formMode" value="add">
                    <div class="group">
                        <label
                            class="block text-sm font-semibold text-slate-700 mb-2 group-focus-within:text-indigo-600 transition-colors">Title</label>
                        <input type="text" id="formTitle" required
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all duration-300 bg-slate-50 focus:bg-white hover:border-indigo-300"
                            placeholder="Enter title">
                    </div>
                    <div class="group">
                        <label
                            class="block text-sm font-semibold text-slate-700 mb-2 group-focus-within:text-indigo-600 transition-colors">Summary
                            Text</label>
                        <textarea id="formSummary" required rows="5"
                            class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 focus:border-indigo-500 transition-all duration-300 bg-slate-50 focus:bg-white hover:border-indigo-300 resize-none"
                            placeholder="Enter summary content"></textarea>
                    </div>
                    <div class="flex justify-end gap-3 mt-8 pt-4 border-t border-slate-50">
                        <button type="button" onclick="closeModal()"
                            class="px-6 py-2.5 rounded-xl font-bold text-slate-600 bg-slate-100 hover:bg-slate-200 transition-all duration-200 active:scale-95">Cancel</button>
                        <button type="submit"
                            class="px-6 py-2.5 rounded-xl font-bold text-white bg-indigo-600 hover:bg-indigo-700 shadow-md shadow-indigo-600/30 hover:shadow-lg hover:shadow-indigo-600/40 transition-all duration-300 active:scale-95">Save
                            Summary</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        const overlay = document.getElementById('crudModalOverlay');
        const modalContainer = document.getElementById('crudModalContent');
        const modalBox = document.getElementById('crudModalBox');
        const crudForm = document.getElementById('crudForm');

        function openModal(mode, id = '', title = '', summary = '') {
            document.getElementById('formMode').value = mode;
            document.getElementById('formId').value = id;
            document.getElementById('formTitle').value = title;
            document.getElementById('formSummary').value = summary;

            document.getElementById('modalTitle').innerText = mode === 'add' ? 'Add New Summary' : 'Edit Summary';

            overlay.classList.remove('hidden');
            modalContainer.classList.remove('hidden');
            modalContainer.classList.add('flex');

            requestAnimationFrame(() => {
                overlay.classList.remove('opacity-0');
                overlay.classList.add('opacity-100');
                modalBox.classList.remove('scale-95', 'opacity-0');
                modalBox.classList.add('scale-100', 'opacity-100');
            });
        }

        function closeModal() {
            overlay.classList.remove('opacity-100');
            overlay.classList.add('opacity-0');
            modalBox.classList.remove('scale-100', 'opacity-100');
            modalBox.classList.add('scale-95', 'opacity-0');

            setTimeout(() => {
                overlay.classList.add('hidden');
                modalContainer.classList.add('hidden');
                modalContainer.classList.remove('flex');
                crudForm.reset();
            }, 300);
        }

        crudForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const submitBtn = e.target.querySelector('button[type="submit"]');
            const originalText = submitBtn.innerText;
            submitBtn.innerText = 'Saving...';
            submitBtn.classList.add('opacity-70', 'cursor-not-allowed');

            const mode = document.getElementById('formMode').value;
            const id = document.getElementById('formId').value;
            const title = document.getElementById('formTitle').value;
            const summary_text = document.getElementById('formSummary').value;

            const url = mode === 'add' ? '/admin/summarize' : `/admin/update/${id}`;
            const method = mode === 'add' ? 'POST' : 'PUT';

            try {
                const response = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title, summary_text })
                });
                const result = await response.json();

                if (result.success) {
                    location.reload();
                } else {
                    alert('Error: ' + result.message);
                    submitBtn.innerText = originalText;
                    submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
                }
            } catch (error) {
                alert('Connection error');
                submitBtn.innerText = originalText;
                submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
            }
        });

        async function deleteSummary(id) {
            if (!confirm('Are you sure? This action cannot be undone.')) return;

            try {
                const row = document.getElementById(`row-${id}`);
                row.style.transform = 'translateX(-20px)';
                row.style.opacity = '0.5';

                const response = await fetch(`/api/delete/${id}`, { method: 'DELETE' });
                const result = await response.json();

                if (result.success) {
                    row.style.transform = 'translateX(-50px)';
                    row.style.opacity = '0';
                    setTimeout(() => {
                        row.remove();
                        if (document.querySelectorAll('tbody tr').length === 0) location.reload();
                    }, 300);
                } else {
                    alert('Error: ' + result.message);
                    row.style.transform = '';
                    row.style.opacity = '1';
                }
            } catch (error) {
                alert('Connection error');
                const row = document.getElementById(`row-${id}`);
                row.style.transform = '';
                row.style.opacity = '1';
            }
        }
    </script>
</body>

</html>